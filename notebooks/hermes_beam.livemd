## 2  Agent Memory — Scratchpad

```elixir
alias HermesBeam.Memory.Scratchpad

scratchpads = Ash.read!(Scratchpad)

IO.puts("\n=== Scratchpad Contents ===")
for pad <- scratchpads do
  memory_pct = Float.round(String.length(pad.memory_text) / 2200 * 100, 1)
  user_pct   = Float.round(String.length(pad.user_text) / 1375 * 100, 1)

  IO.puts("""
  Agent: #{pad.agent_id}
    memory_text  [#{memory_pct}% of 2200]
    user_text    [#{user_pct}% of 1375]
  """)
end

scratchpads
```

```elixir
query = "What has the agent learned about the user?"

results =
  HermesBeam.Memory.Episodic
  |> Ash.Query.for_read(:recall_similar, %{query: query})
  |> Ash.read!()

IO.puts("\n=== Top-5 Memories for: '#{query}' ===")
for mem <- results do
  IO.puts("  [#{mem.type}] #{String.slice(mem.content, 0, 120)}...")
end

results
```

