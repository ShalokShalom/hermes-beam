## 3  Reactor Workflow Log

```elixir
alias HermesBeam.WorkflowLog

recent_runs =
  WorkflowLog
  |> Ash.Query.sort(started_at: :desc)
  |> Ash.Query.limit(25)
  |> Ash.read!()

IO.puts("\n=== Recent Workflow Runs ===")
for run <- recent_runs do
  duration =
    if run.finished_at do
      "#{DateTime.diff(run.finished_at, run.started_at, :millisecond)}ms"
    else
      "running..."
    end
  IO.puts("  [#{run.status}]  #{run.workflow_name}  |  #{duration}  |  #{run.started_at}")
end

recent_runs
```

---

## 4  Skill Registry

```elixir
alias HermesBeam.Skill

skills = Ash.read!(Skill, query: Ash.Query.sort(Skill, execution_count: :desc))

IO.puts("\n=== Skills (#{length(skills)} total) ===")
for skill <- skills do
  rate_label =
    cond do
      skill.success_rate >= 0.9 -> "✅ #{Float.round(skill.success_rate * 100, 1)}%"
      skill.success_rate >= 0.7 -> "⚠️  #{Float.round(skill.success_rate * 100, 1)}%"
      true                      -> "❌ #{Float.round(skill.success_rate * 100, 1)}%"
    end
  IO.puts("  #{skill.name}  |  #{skill.execution_count}x  |  #{rate_label}")
end

skills
```

