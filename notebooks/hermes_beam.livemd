# Hermes BEAM — Interactive Dashboard

```elixir
Mix.install(
  [
    {:hermes_beam, path: Path.join(__DIR__, ".."), env: :dev}
  ],
  config_path: :hermes_beam,
  lockfile: :hermes_beam
)
```

## Welcome to Hermes BEAM

This notebook is the **primary observability interface** for your distributed AI agent cluster.
Connect to a running Hub node via the **Attached Node** runtime and every cell below
executes in the live cluster context — no REST API, no separate service, just
direct function calls into the running BEAM.

> **How to connect:**
> 1. Start the Hub: `bash bin/start_node.sh` (with `NODE_TYPE=hub`)
> 2. Run: `bash bin/livebook_connect.sh` to launch Livebook pre-attached to the Hub
> 3. Open this notebook — the runtime is pre-configured

---

## 1  Cluster Status

```elixir
connected_nodes = [Node.self() | Node.list()]

IO.puts("\n=== Connected Nodes ===")
for node <- connected_nodes do
  role =
    try do
      :rpc.call(node, Application, :fetch_env!, [:hermes_beam, :topology], 5_000)
      |> Keyword.get(:role, "unknown")
    catch
      _, _ -> "unreachable"
    end

  status = if node == Node.self() or node in Node.list(), do: "✅ online", else: "❌ offline"
  IO.puts("  #{node}  |  role: #{role}  |  #{status}")
end

connected_nodes
```

```elixir
tiers_by_node =
  for node <- connected_nodes, into: %{} do
    tiers =
      try do
        topology = :rpc.call(node, Application, :fetch_env!, [:hermes_beam, :topology], 5_000)
        Keyword.get(topology, :active_tiers, [])
      catch
        _, _ -> []
      end
    {node, tiers}
  end

IO.puts("\n=== Nx.Serving Tiers ===")
for {node, tiers} <- tiers_by_node do
  IO.puts("  Node: #{node}")
  for {tier, model} <- tiers, do: IO.puts("    #{tier}  ->  #{model}")
end

tiers_by_node
```

