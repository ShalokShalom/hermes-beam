## 6  Raw Postgres Queries

```elixir
import Ecto.Query

daily_counts =
  from(m in "agent_memories",
    select: %{
      day: fragment("date_trunc('day', ?)", m.inserted_at),
      count: count(m.id)
    },
    group_by: fragment("date_trunc('day', ?)", m.inserted_at),
    order_by: [asc: fragment("date_trunc('day', ?)", m.inserted_at)]
  )
  |> HermesBeam.Repo.all()

IO.puts("\n=== Episodic Memory Growth ===")
for %{day: day, count: n} <- daily_counts do
  bar = String.duplicate("█", min(n, 60))
  IO.puts("  #{day}  #{String.pad_leading("#{n}", 5)}  #{bar}")
end

daily_counts
```
